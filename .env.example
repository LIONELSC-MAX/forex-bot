# Salin file ini ke ".env" lalu isi semua value di bawah
# Analisis sinyal 100% berbasis rumus teknikal (RSI, MA crossover) - tidak ada API AI berbayar yang dipakai

# API key dari twelvedata.com (gratis, 800 request/hari)
TWELVEDATA_API_KEY=

# VAPID keys untuk push notification - generate dengan: npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:email-kamu@example.com

# Port server (boleh dibiarkan default)
PORT=3000

# Interval scan otomatis dalam detik (default 300 = 5 menit)
SCAN_INTERVAL_SECONDS=300

# Daftar pair yang dipantau, pisahkan dengan koma
WATCHED_PAIRS=EUR/USD,GBP/USD,USD/JPY,AUD/USD,USD/CHF,NZD/USD

# Timeframe candle: 1h, 4h, atau 1day
TIMEFRAME=4h
